<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Transactions</h1>
  <%= link_to "Back to accounts", accounts_path, class: "btn btn-outline-secondary" %>
</div>

<% if @transactions.empty? %>
  <div class="alert alert-info">No transactions found.</div>
<% else %>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Date</th>
        <th>Amount</th>
        <th>Currency</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <% @transactions.each do |tx| %>
        <tr>
          <td><%= tx["bookingDate"] %></td>
          <td><%= tx.dig("transactionAmount", "amount") %></td>
          <td><%= tx.dig("transactionAmount", "currency") %></td>
          <td><%= tx["remittanceInformationUnstructured"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
